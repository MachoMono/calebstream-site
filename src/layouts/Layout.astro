---
import ThemePicker from "../components/ThemePicker";
interface Props {
  title?: string;
}
const { title = "calebstillstreams" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="calebstillstreams — Twitch streamer, feed, misc transmissions" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&family=Barlow+Condensed:wght@700;900&display=swap"
      rel="stylesheet"
    />
    <!-- Apply saved theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("calebstream-theme");
          if (t) document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <!-- Google Identity Services -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* ── LCD (default) ── */
      :root, [data-theme="lcd"] {
        --yellow:    #F9C424;
        --fg:        #000000;
        --bg:        #eaeae4;
        --fg-dim:    #666666;
        --border:    #b0b0aa;
        --bg-dim:    #d8d8d2;
        --bg-hover:  #d0d0ca;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── SNES ── */
      /* Colors from actual SNES hardware: gray body, periwinkle/purple buttons */
      [data-theme="snes"] {
        --yellow:    #6860a8;
        --fg:        #a8a8d0;
        --bg:        #262636;
        --fg-dim:    #565668;
        --border:    #40405e;
        --bg-dim:    #1a1a28;
        --bg-hover:  #303048;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── Sega Genesis ── */
      /* Colors from actual Genesis hardware: near-black body, crimson/orange accents */
      [data-theme="genesis"] {
        --yellow:    #cc6028;
        --fg:        #d82020;
        --bg:        #120808;
        --fg-dim:    #702020;
        --border:    #2e0c0c;
        --bg-dim:    #0c0606;
        --bg-hover:  #1e1010;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── PlayStation ── */
      /* Colors from PlayStation logo: crimson red, gold, teal, royal blue */
      [data-theme="playstation"] {
        --yellow:    #cc1422;
        --fg:        #d0d8f8;
        --bg:        #070710;
        --fg-dim:    #4460a8;
        --border:    #1a2862;
        --bg-dim:    #040610;
        --bg-hover:  #0e1840;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── GameCube ── */
      /* Colors from GameCube hardware: indigo body, controller buttons (purple, gold, green, red) */
      [data-theme="gamecube"] {
        --yellow:    #c8a818;
        --fg:        #cc88ee;
        --bg:        #0c0018;
        --fg-dim:    #6030a0;
        --border:    #340068;
        --bg-dim:    #160028;
        --bg-hover:  #220040;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── Bombpop ── */
      /* Colors from the actual Bomb Pop popsicle: blue-raspberry teal, white, cherry red */
      [data-theme="bombpop"] {
        --yellow:    #12a8c0;
        --fg:        #d41428;
        --bg:        #ffffff;
        --fg-dim:    #bb3344;
        --border:    #e0c8cc;
        --bg-dim:    #f0f8f9;
        --bg-hover:  #e4f6f8;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      html, body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-mono);
        font-size: 0.9rem;
        line-height: 1.6;
        min-height: 100%;
      }

      /* ── BANNER ── */
      .banner {
        width: 100%;
        height: 140px;
        overflow: hidden;
        position: relative;
        border-bottom: 3px solid var(--yellow);
        flex-shrink: 0;
      }
      .banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        display: block;
        filter: contrast(1.05) saturate(0.85);
      }

      /* ── NAV ── */
      .site-nav {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 1rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        flex-wrap: wrap;
      }
      .site-nav .logo {
        width: 28px;
        height: 28px;
        border-radius: 2px;
        border: 1px solid var(--border);
        object-fit: cover;
        flex-shrink: 0;
      }
      .site-nav .site-title {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--fg);
        text-decoration: none;
        letter-spacing: 0.05em;
      }
      .site-nav .site-title::before { content: '['; color: var(--fg-dim); }
      .site-nav .site-title::after  { content: ']'; color: var(--fg-dim); }
      .site-nav .nav-links {
        display: flex;
        gap: 0;
        flex-wrap: wrap;
      }
      .site-nav .nav-links a {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--fg-dim);
        text-decoration: none;
        padding: 0.15rem 0.55rem;
        border: 1px solid var(--border);
        margin-left: -1px;
        transition: color 0.1s, background 0.1s;
      }
      .site-nav .nav-links a:hover { color: var(--fg); background: var(--bg-hover); }
      .site-nav .nav-links a.active { background: var(--fg); color: var(--bg); }
      .site-nav .nav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      /* ── FOOTER ── */
      .site-footer {
        padding: 1.25rem 1rem;
        border-top: 1px solid var(--border);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--fg-dim);
        text-align: center;
        background: var(--bg);
      }
      .site-footer a { color: var(--fg-dim); }
      .site-footer a:hover { color: var(--fg); }
    </style>
  </head>
  <body>
    <div class="banner">
      <img src="/banner.png" alt="" />
    </div>

    <nav class="site-nav">
      <img src="/logo.png" alt="" class="logo" />
      <a href="/" class="site-title">calebstillstreams</a>
      <div class="nav-links">
        <a href="/" class="active">Feed</a>
        <a href="https://www.twitch.tv/calebstillstreams" target="_blank" rel="noopener">Twitch</a>
        <a href="https://www.youtube.com/@calebstillstreams" target="_blank" rel="noopener">YouTube</a>
      </div>
      <div class="nav-right">
        <ThemePicker client:load />
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      calebstillstreams · <a href="https://github.com/MachoMono/calebstream-site">source</a>
    </footer>
  </body>
</html>
