---
interface Props {
  title?: string;
}
const { title = "calebstillstreams" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="calebstillstreams — Twitch streamer, feed, misc transmissions" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Google Identity Services -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --yellow:   #F9C424;
        --dark:     #0d0d0d;
        --panel-bg: #111;
        --text:     #e8e8e8;
        --muted:    #888;
        --border:   #1c1c1c;
      }

      html, body {
        background: var(--dark);
        color: var(--text);
        font-family: 'Barlow', sans-serif;
        font-size: 1rem;
        line-height: 1.6;
        min-height: 100%;
      }

      /* ── BANNER ── */
      .banner {
        width: 100%;
        height: 150px;
        overflow: hidden;
        position: relative;
        border-bottom: 3px solid var(--yellow);
        flex-shrink: 0;
      }
      .banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        display: block;
        filter: contrast(1.05) saturate(0.9);
      }
      .banner::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 50%, var(--dark) 100%);
      }

      /* ── NAV ── */
      .site-nav {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 1.25rem;
        border-bottom: 2px solid var(--border);
        background: var(--dark);
        flex-wrap: wrap;
      }
      .site-nav .logo {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 2px solid var(--yellow);
        object-fit: cover;
        flex-shrink: 0;
      }
      .site-nav .site-title {
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 900;
        font-size: 1.4rem;
        color: var(--yellow);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        text-decoration: none;
        line-height: 1;
      }
      .site-nav .nav-links {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .site-nav .nav-links a {
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        text-decoration: none;
        padding: 0.2rem 0.5rem;
        border: 1px solid #2a2a2a;
        transition: border-color 0.15s, color 0.15s;
      }
      .site-nav .nav-links a:hover,
      .site-nav .nav-links a.active { border-color: var(--yellow); color: var(--yellow); }

      .site-nav .nav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      /* ── FOOTER ── */
      .site-footer {
        padding: 1.5rem 1.25rem;
        border-top: 1px solid var(--border);
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.7rem;
        color: var(--muted);
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="banner">
      <img src="/banner.png" alt="" />
    </div>

    <nav class="site-nav">
      <img src="/logo.png" alt="" class="logo" />
      <a href="/" class="site-title">calebstillstreams</a>
      <div class="nav-links">
        <a href="/" class="active">Feed</a>
        <a href="https://www.twitch.tv/calebstillstreams" target="_blank" rel="noopener">Twitch</a>
        <a href="https://www.youtube.com/@calebstillstreams" target="_blank" rel="noopener">YouTube</a>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      calebstillstreams · built with astro · <a href="https://github.com/MachoMono/calebstream-site" style="color:var(--muted)">source</a>
    </footer>
  </body>
</html>
