---
import ThemePicker from "../components/ThemePicker";
interface Props {
  title?: string;
}
const { title = "calebstillstreams" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="calebstillstreams — Twitch streamer, feed, misc transmissions" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&family=Barlow+Condensed:wght@700;900&display=swap"
      rel="stylesheet"
    />
    <!-- Apply saved theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("calebstream-theme");
          if (t) document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <!-- Google Identity Services -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* ── LCD (default) ── */
      :root, [data-theme="lcd"] {
        --yellow:    #F9C424;
        --fg:        #000000;
        --bg:        #eaeae4;
        --fg-dim:    #666666;
        --border:    #b0b0aa;
        --bg-dim:    #d8d8d2;
        --bg-hover:  #d0d0ca;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── SNES ── */
      /* Palette: #A7A4E0 #514689 #B2B4B2 #54585A #707372 */
      [data-theme="snes"] {
        --yellow:    #514689;
        --fg:        #A7A4E0;
        --bg:        #222234;
        --fg-dim:    #707372;
        --border:    #54585A;
        --bg-dim:    #181822;
        --bg-hover:  #2e2e42;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── Sega Genesis ── */
      /* Palette: #ECCDCC #291415 #A5171A #D86E39 #FFFFCC */
      [data-theme="genesis"] {
        --yellow:    #A5171A;
        --fg:        #FFFFCC;
        --bg:        #291415;
        --fg-dim:    #D86E39;
        --border:    #4a2020;
        --bg-dim:    #1c0e0f;
        --bg-hover:  #361c1d;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── PlayStation ── */
      /* PS1 body gray + palette: #DF0024 red · #F3C300 gold · #00AB9F teal · #2E6DB4 blue */
      [data-theme="playstation"] {
        --yellow:    #DF0024;
        --fg:        #1a1a1a;
        --bg:        #b0b0ac;
        --fg-dim:    #2E6DB4;
        --border:    #00AB9F;
        --bg-dim:    #a4a4a0;
        --bg-hover:  #a8a8a4;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── GameCube ── */
      /* Palette: #A631CD #DDDDDD #E1D021 #21C925 #E52F2F */
      [data-theme="gamecube"] {
        --yellow:    #E1D021;
        --fg:        #DDDDDD;
        --bg:        #0c0018;
        --fg-dim:    #A631CD;
        --border:    #50107a;
        --bg-dim:    #160028;
        --bg-hover:  #220040;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      /* ── Bombpop ── */
      /* Palette: #0FA6C2 #08B8CD #FFFFFF #FF102E #FF001F */
      [data-theme="bombpop"] {
        --yellow:    #0FA6C2;
        --fg:        #FF102E;
        --bg:        #FFFFFF;
        --fg-dim:    #dd2040;
        --border:    #f0cccc;
        --bg-dim:    #eafcff;
        --bg-hover:  #d8f8fc;
        --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      }

      html, body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-mono);
        font-size: 0.9rem;
        line-height: 1.6;
        min-height: 100%;
      }

      /* ── BANNER ── */
      .banner {
        width: 100%;
        height: 140px;
        overflow: hidden;
        position: relative;
        border-bottom: 3px solid var(--yellow);
        flex-shrink: 0;
      }
      .banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        display: block;
        filter: contrast(1.05) saturate(0.85);
      }

      /* ── NAV ── */
      .site-nav {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 1rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        flex-wrap: wrap;
      }
      .site-nav .logo {
        width: 28px;
        height: 28px;
        border-radius: 2px;
        border: 1px solid var(--border);
        object-fit: cover;
        flex-shrink: 0;
      }
      .site-nav .site-title {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--fg);
        text-decoration: none;
        letter-spacing: 0.05em;
      }
      .site-nav .site-title::before { content: '['; color: var(--fg-dim); }
      .site-nav .site-title::after  { content: ']'; color: var(--fg-dim); }
      .site-nav .nav-links {
        display: flex;
        gap: 0;
        flex-wrap: wrap;
      }
      .site-nav .nav-links a {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--fg-dim);
        text-decoration: none;
        padding: 0.15rem 0.55rem;
        border: 1px solid var(--border);
        margin-left: -1px;
        transition: color 0.1s, background 0.1s;
      }
      .site-nav .nav-links a:hover { color: var(--fg); background: var(--bg-hover); }
      .site-nav .nav-links a.active { background: var(--fg); color: var(--bg); }
      .site-nav .nav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      /* ── FOOTER ── */
      .site-footer {
        padding: 1.25rem 1rem;
        border-top: 1px solid var(--border);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--fg-dim);
        text-align: center;
        background: var(--bg);
      }
      .site-footer a { color: var(--fg-dim); }
      .site-footer a:hover { color: var(--fg); }
    </style>
  </head>
  <body>
    <div class="banner">
      <img src="/banner.png" alt="" />
    </div>

    <nav class="site-nav">
      <img src="/logo.png" alt="" class="logo" />
      <a href="/" class="site-title">calebstillstreams</a>
      <div class="nav-links">
        <a href="/" class="active">Feed</a>
        <a href="https://www.twitch.tv/calebstillstreams" target="_blank" rel="noopener">Twitch</a>
        <a href="https://www.youtube.com/@calebstillstreams" target="_blank" rel="noopener">YouTube</a>
      </div>
      <div class="nav-right">
        <ThemePicker client:load />
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      calebstillstreams · <a href="https://github.com/MachoMono/calebstream-site">source</a>
    </footer>
  </body>
</html>
